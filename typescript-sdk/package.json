{
  "name": "mcpbuilder-ai",
  "version": "0.1.0",
  "description": "TypeScript SDK for MCPBuilder - MCP agent integration with chat interface",
  "author": "Apichap solutions FlexCo <office@mcp-builder.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/apichamp/apichamp-ai/mcp-integration-sdk/typescript-sdk"
  },
  "homepage": "https://mcp-builder.ai",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "chat",
    "websocket",
    "mcpbuilder"
  ],
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && npm run fix:cjs",
    "build:types": "tsc -p tsconfig.types.json",
    "fix:cjs": "node scripts/fix-cjs.js",
    "clean": "rimraf dist",
    "dev": "tsc -p tsconfig.esm.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "eslint": "^9.0.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.2.0"
  },
  "peerDependencies": {},
  "publishConfig": {
    "access": "public"
  }
}
